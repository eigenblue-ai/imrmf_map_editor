    package = "serde",
    version = "1",
)
crate.spec(
    package = "serde-big-array",
    version = "0.5",
)
crate.spec(
    package = "serde_json",
    version = "1",
)
crate.spec(
    package = "yrs",
    version = "0.21",
)
crate.spec(
    features = ["ws"],
    package = "axum",
    version = "0.7",
)
crate.spec(
    features = ["full"],
    package = "tokio",
