)
crate.spec(
    package = "tempfile",
    version = "3",
)
crate.spec(
    package = "async-trait",
    version = "0.1",
)
crate.spec(
    features = ["behavior-version-latest"],
    package = "aws-config",
    version = "1",
)
crate.spec(
    package = "aws-credential-types",
    version = "1",
)
crate.spec(
    features = ["behavior-version-latest"],
    package = "aws-sdk-s3",
    version = "1",
