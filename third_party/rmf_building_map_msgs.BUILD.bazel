load(
    "@com_github_mvukov_rules_ros2//ros2:interfaces.bzl",
    "py_ros2_interface_library",
    "ros2_interface_library",
)

package(default_visibility = ["//visibility:public"])

ros2_interface_library(
    name = "rmf_building_map_msgs",
    srcs = glob([
        "rmf_building_map_msgs/msg/*.msg",
        "rmf_building_map_msgs/srv/*.srv",
    ]),
)

py_ros2_interface_library(
    name = "py_rmf_building_map_msgs",
    deps = [":rmf_building_map_msgs"],
)
